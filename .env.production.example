# ============================================================
# Evolv — Production Environment Variables
# ============================================================
# Copy this file to /opt/evolv/.env on your Hetzner server
# and fill in the values below.
#
# NEVER commit the actual .env file to version control.
# ============================================================

# ── Docker Hub ───────────────────────────────────────────
DOCKERHUB_USERNAME=yourusername

# ── Database (Neon DB) ───────────────────────────────────
# Get your connection string from: https://console.neon.tech
# Use the "Pooled connection" string from your Neon dashboard.
DATABASE_URL=postgresql://***REDACTED_USER***:YOUR_PASSWORD@ep-xxxxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_ME_GENERATE_WITH_OPENSSL_RAND_HEX_32

# Your Gemini API key for AI features
GEMINI_API_KEY=your-gemini-api-key

# The public URL of your frontend (used for CORS)
ALLOWED_ORIGIN=https://evolv.yourdomain.com

# ── Client (build-time — set as GitHub Actions secret) ───
# This is baked into the JS bundle during the Docker build.
# Set VITE_API_URL as a GitHub secret, not here.
# Example: https://evolv.yourdomain.com/api
